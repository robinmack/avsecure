# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real credentials.

# ── TURN server credentials (required for calls across strict NATs) ──────────
#
# Without TURN, peers behind symmetric NAT (many corporate/mobile networks)
# will fail to connect. STUN-only works fine on most home connections.
#
# Recommended provider: https://www.metered.ca/tools/openrelay/
#   1. Create a free account at metered.ca
#   2. Go to Dashboard → TURN Credentials
#   3. Copy the username and credential below
#
# Other providers: Twilio (twilio.com/stun-turn), Xirsys (xirsys.com)
#
REACT_APP_TURN_USERNAME=your_turn_username_here
REACT_APP_TURN_CREDENTIAL=your_turn_credential_here
